@startuml composition-relationships
title ova-lib — Inheritance and Composition Relationships

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ArrowColor #444444
skinparam ClassBorderColor #555555
skinparam ClassBackgroundColor #FAFAFA
skinparam InterfaceBackgroundColor #EAF4FB
skinparam InterfaceBorderColor #2E86C1
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

' ════════════════════════════════════════════════════════════════
' Foundation types
' ════════════════════════════════════════════════════════════════
package "types.h — Foundation" #F0FFF0 {
    class types <<(T,#AADDAA) typedefs>> {
        + comparator    : int (*)(void*, void*)
        + hash_func_t   : unsigned (*)(void*, size_t)
        + vector        : \{ double *data; int size; int capacity; \}
        + bool          : (stdbool.h)
    }
}

' ════════════════════════════════════════════════════════════════
' Vtable-based "interfaces" (C polymorphism via function pointers)
' ════════════════════════════════════════════════════════════════
package "Vtable Interfaces" #EAF4FB {

    interface IList <<vtable>> {
        + insert(index, item)
        + get(index) : void*
        + remove(index)
        + size() : int
        + free()
    }

    interface IHeap <<vtable>> {
        + put(item)
        + put_with_handle(item) : void*
        + decrease_key(handle, val)
        + delete_node(handle)
        + pop() : void*
        + peek() : void*
        + size() : int
        + free()
    }

    interface IStack <<vtable>> {
        + push(item)
        + pop() : void*
        + top() : void*
        + is_empty() : int
        + size() : int
        + free()
    }

    interface ITree <<vtable>> {
        + insert(key, value)
        + search(key) : void*
        + delete(key)
        + min() : void*
        + max() : void*
        + predecessor(key) : void*
        + successor(key) : void*
        + range_query(low, high) : IList*
        + in_order_traverse(cb)
        + size() : int
        + free()
    }

    interface ISet <<vtable>> {
        + add(element) : bool
        + contains(element) : bool
        + remove(element) : bool
        + size() : int
        + union/intersection/difference
        + to_list() : IList*
    }
}

' ════════════════════════════════════════════════════════════════
' Concrete implementations
' ════════════════════════════════════════════════════════════════
package "List Implementations" #FFF8E1 {
    class ArrayList <<concrete>> {
        - void **data
        - int size, capacity
    }
    class LinkedList <<concrete>> {
        - node *head
        - node *tail
        - int size
    }
    class SortedList <<concrete>> {
        - void **data
        - int size, capacity
        - comparator cmp
    }

    IList <|.. ArrayList  : implements
    IList <|.. LinkedList : implements
    IList <|.. SortedList : implements

    note right of SortedList
      Keeps elements ordered;
      binary-search insert O(log n),
      shift cost O(n).
    end note
}

package "Heap Implementations" #FFF0F0 {
    class BinaryHeap <<concrete>> {
        - void **data  [0-indexed array]
        - int size, capacity
        - comparator cmp
        - decrease_key = NULL
        - delete_node  = NULL
    }
    class FibonacciHeap <<concrete>> {
        - fib_node *min_node
        - int size
        - comparator cmp
    }

    IHeap <|.. BinaryHeap    : implements
    IHeap <|.. FibonacciHeap : implements

    note right of FibonacciHeap
      Amortized O(1) insert,\nO(log n) extract-min,\nO(1) decrease_key.
    end note
}

package "Stack Implementations" #F0FFF0 {
    class ArrayStack <<concrete>> {
        - void **data
        - int top, capacity
    }
    class LinkedStack <<concrete>> {
        - stack_node *top
        - int size
    }

    IStack <|.. ArrayStack  : implements
    IStack <|.. LinkedStack : implements
}

package "Tree Implementations" #F5F0FF {
    class AVLTree <<concrete>> {
        - avl_node *root
        - int size
        - comparator cmp
    }
    class RedBlackTree <<concrete>> {
        - rb_node *root
        - rb_node *nil_sentinel
        - int size
        - comparator cmp
    }

    ITree <|.. AVLTree      : implements
    ITree <|.. RedBlackTree : implements
}

package "Set Implementations" #FFF5F5 {
    class HashSet <<concrete>> {
        - map *backing_map
        - comparator cmp
        - hash_func_t hash
    }
    class TreeSet <<concrete>> {
        - tree *backing_tree
    }

    ISet <|.. HashSet : implements
    ISet <|.. TreeSet : implements
}

' ════════════════════════════════════════════════════════════════
' Composition relationships
' ════════════════════════════════════════════════════════════════
package "Queue (composition)" #E8F8E8 {
    class Queue <<composite>> {
        - queue_entry *front, *rear  [normal mode]
        - IHeap       *p_heap        [priority mode]
        - int length
        + enqueue / dequeue
    }

    Queue o-- IHeap : priority queue\nuses heap
}

package "Map (self-contained)" #FDF0E8 {
    class Map <<composite>> {
        - map_entry **buckets
        - int capacity, size
        - hash_func   [pluggable]
        - comparator  key_compare
        - pthread_mutex_t *lock  [optional]
        + put / get / remove
    }

    note right of Map
      HASH_TABLE variant adds\n
      a pthread_mutex_t for\n
      coarse-grained thread safety.
    end note
}

package "Solver (composition)" #EFF0FF {
    class Solver <<composite>> {
        - SolverType type
        + solve(problem) : int
        + destroy()
    }

    class LPProblem <<composite>> {
        - matrix *constraints
        - vector *objective
        - vector *bounds
        - ProblemType type
        - double *solution
        - double  z_value
        + addConstraint / setObjective / setBounds
    }

    class Matrix <<concrete>> {
        - double **data
        - int rows, cols
    }

    Solver "1" --> "1" LPProblem : solves >
    LPProblem *-- Matrix         : constraints\nmatrix
    LPProblem *-- types          : uses vector
}

' ════════════════════════════════════════════════════════════════
' Cross-cutting dependencies on types
' ════════════════════════════════════════════════════════════════
IList    ..> types : uses comparator
IHeap    ..> types : uses comparator
IStack   ..> types : uses types
ITree    ..> types : uses comparator
ISet     ..> types : uses comparator\n& hash_func_t
Map      ..> types : uses comparator\n& hash_func_t
Queue    ..> types : uses comparator

' ════════════════════════════════════════════════════════════════
' Cross-module composition
' ════════════════════════════════════════════════════════════════
TreeSet  --> ITree  : wraps
HashSet  --> Map    : wraps
ISet     ..> IList  : set_to_list()\nreturns IList*
ITree    ..> IList  : range_query()\nreturns IList*

' ════════════════════════════════════════════════════════════════
' Graph (direct-function module, two representations)
' ════════════════════════════════════════════════════════════════
package "Graph" #F0FFFF {
    class Graph <<composite>> {
        - graph_type type          [DIRECTED | UNDIRECTED]
        - graph_representation rep [ADJ_LIST | ADJ_MATRIX]
        - list **adj_lists         [ADJ_LIST path]
        - double *adj_matrix       [ADJ_MATRIX path]
        + add_vertex / add_edge / remove_edge
        + bfs / dfs / dijkstra / bellman_ford
        + mst_prim / mst_kruskal
        + floyd_warshall
    }

    Graph o-- IList : adj_lists\nuse list*
    Graph ..> "Matrix (matrix.h)" : floyd_warshall\nreturns matrix*
}

' ════════════════════════════════════════════════════════════════
' Trie (self-contained prefix tree)
' ════════════════════════════════════════════════════════════════
package "Trie (self-contained)" #FFFFF0 {
    class Trie <<concrete>> {
        - trie_node *root
        - size_t word_count
        + insert / search / delete
        + starts_with / get_words_with_prefix
    }

    Trie ..> IList : get_words_with_prefix()\nreturns list*
}

' ════════════════════════════════════════════════════════════════
' Bloom Filter (self-contained probabilistic set)
' ════════════════════════════════════════════════════════════════
package "Bloom Filter (self-contained)" #FFF0FF {
    class BloomFilter <<concrete>> {
        - uint8_t *bits
        - size_t m_bits, k_hashes
        + add / might_contain
        + current_fpp / clear
    }
}

' ════════════════════════════════════════════════════════════════
' Sorter (vtable adapter over lists)
' ════════════════════════════════════════════════════════════════
package "Sorter (vtable)" #F5FFF0 {
    interface ISorter <<vtable>> {
        + sort(lst)
        + shuffle(lst)
        + reverse(lst)
        + binary_search(lst, item) : int
        + swap(lst, i, j)
        + min / max / min_max
        + copy(src, dest)
    }

    ISorter ..> IList : operates on list*
    ISorter ..> types : uses comparator
}

' ════════════════════════════════════════════════════════════════
' Deque (self-contained circular buffer)
' ════════════════════════════════════════════════════════════════
package "Deque (self-contained)" #F0FFF8 {
    class Deque <<concrete>> {
        - void **buffer  [circular]
        - int capacity, size, front
        + push_front / push_back
        + pop_front / pop_back
        + peek_front / peek_back / get
    }
}

' ════════════════════════════════════════════════════════════════
' Matrix / Vector (vtable with function pointers)
' ════════════════════════════════════════════════════════════════
package "Matrix / Vector (vtable)" #FFF8F0 {
    interface IMatrix <<vtable>> {
        + add / subtract / multiply
        + determinant / inverse / transpose
        + resize / copy / print / destroy
    }

    class Vector <<concrete>> {
        - double *data
        - int size
        + resize / print / destroy
    }
}

@enduml
