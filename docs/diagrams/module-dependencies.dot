/* ova-lib — Module Dependency Graph
 *
 * Render with:  dot -Tsvg module-dependencies.dot -o module-dependencies.svg
 *               dot -Tpng module-dependencies.dot -o module-dependencies.png
 */
digraph ova_lib_modules {
    rankdir = TB;
    compound = true;
    graph [fontname="Helvetica", fontsize=12, bgcolor="#FFFFFF",
           label="ova-lib Module Dependencies", labelloc=t, labeljust=c];
    node  [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled",
           fillcolor="#E8F4FD", color="#2980B9", penwidth=1.5];
    edge  [fontname="Helvetica", fontsize=10, color="#555555", arrowsize=0.8];

    /* ── Umbrella ─────────────────────────────────────────────── */
    subgraph cluster_umbrella {
        label="Public API";
        style=filled;
        color="#D5E8D4";
        fillcolor="#F0FFF0";
        ova_h [label="ova.h\n(umbrella header)", fillcolor="#A9D18E"];
    }

    /* ── Foundation ──────────────────────────────────────────── */
    subgraph cluster_foundation {
        label="Foundation";
        style=filled;
        color="#DAE8FC";
        fillcolor="#F5F9FF";
        types_h [label="types.h\n(comparator, hash_func_t,\nbool, vector)"];
        matrix_h [label="matrix.h / matrix.c\n(matrix, vector)"];
    }

    /* ── Containers ──────────────────────────────────────────── */
    subgraph cluster_containers {
        label="Containers";
        style=filled;
        color="#FFE6CC";
        fillcolor="#FFFAF0";

        list_h   [label="list.h / list.c\n(array_list, linked_list,\nsorted_list)"];
        heap_h   [label="heap.h / heap.c\n(binary_heap,\nfibonacci_heap)"];
        queue_h  [label="queue.h / queue.c\n(linked_queue,\nheap_queue)"];
        stack_h  [label="stack.h / stack.c\n(array_stack,\nlinked_stack)"];
        deque_h  [label="deque.h / deque.c\n(circular buffer)"];
        map_h    [label="map.h / map.c\n(hash_map, hash_table)"];
        set_h    [label="set.h / set.c\n(hash_set, tree_set)"];
        tree_h   [label="tree.h / tree.c\n(AVL, Red-Black)"];
        trie_h   [label="trie.h / trie.c\n(prefix tree)"];
        graph_h  [label="graph.h / graph.c\n(adjacency list/matrix,\nBFS/DFS/Dijkstra/…)"];
        bloom_h  [label="bloom_filter.h / bloom_filter.c\n(probabilistic membership)"];
    }

    /* ── Algorithms ──────────────────────────────────────────── */
    subgraph cluster_algorithms {
        label="Algorithms";
        style=filled;
        color="#E1D5E7";
        fillcolor="#FDF5FF";
        sort_h   [label="sort.h / sort.c\n(sorter vtable)"];
    }

    /* ── Solver ──────────────────────────────────────────────── */
    subgraph cluster_solver {
        label="Linear Programming";
        style=filled;
        color="#F8CECC";
        fillcolor="#FFF5F5";
        solver_h [label="solver.h / solver.c\n(lp_problem, simplex,\nbranch-and-bound stubs)"];
    }

    /* ── Edges from umbrella ─────────────────────────────────── */
    ova_h -> list_h   [style=dashed, color="#27AE60"];
    ova_h -> heap_h   [style=dashed, color="#27AE60"];
    ova_h -> queue_h  [style=dashed, color="#27AE60"];
    ova_h -> stack_h  [style=dashed, color="#27AE60"];
    ova_h -> map_h    [style=dashed, color="#27AE60"];
    ova_h -> set_h    [style=dashed, color="#27AE60"];
    ova_h -> tree_h   [style=dashed, color="#27AE60"];
    ova_h -> trie_h   [style=dashed, color="#27AE60"];
    ova_h -> graph_h  [style=dashed, color="#27AE60"];
    ova_h -> sort_h   [style=dashed, color="#27AE60"];
    ova_h -> bloom_h  [style=dashed, color="#27AE60"];

    /* ── Foundation dependencies ─────────────────────────────── */
    list_h   -> types_h;
    heap_h   -> types_h;
    queue_h  -> types_h;
    stack_h  -> types_h;
    deque_h  -> types_h;
    map_h    -> types_h;
    set_h    -> types_h;
    tree_h   -> types_h;
    trie_h   -> types_h;
    graph_h  -> types_h;
    bloom_h  -> types_h;
    sort_h   -> list_h;
    solver_h -> types_h;
    solver_h -> matrix_h;

    /* ── Cross-module dependencies ───────────────────────────── */
    queue_h  -> heap_h   [label="priority queue\nuses heap"];
    map_h    -> heap_h   [label="create_map\naccepts heap\ncapacity hint", style=dotted];
    set_h    -> list_h   [label="set_to_list()"];
    set_h    -> map_h    [label="SET_HASH\nwraps map"];
    set_h    -> tree_h   [label="SET_TREE\nuses tree"];
    trie_h   -> list_h   [label="get_words_with_prefix()\nreturns list*"];
    tree_h   -> list_h   [label="tree_range_query()\nreturns list*"];
    graph_h  -> list_h   [label="neighbor lists,\nBFS/DFS results"];
    graph_h  -> matrix_h [label="floyd_warshall\nreturns matrix*"];
}
