@startuml memory-layouts
title ova-lib — Memory Layout of Key Structures

skinparam monochrome false
skinparam classAttributeIconSize 0
skinparam ClassBorderColor #555555
skinparam ClassBackgroundColor #F9F9F9
skinparam ArrowColor #444444
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

' ═══════════════════════════════════════════════════════════════
' types.h — foundation
' ═══════════════════════════════════════════════════════════════
class "types.h" <<(T,#AADDAA) typedef>> {
    typedef int (*comparator)(void*, void*)
    typedef unsigned (*hash_func_t)(void*, size_t)
    typedef struct \{ double *data; int size; int capacity; \} vector
    typedef bool (from <stdbool.h>)
}

' ═══════════════════════════════════════════════════════════════
' list — vtable + opaque impl
' ═══════════════════════════════════════════════════════════════
class list <<struct>> {
    + void  *impl          [8 bytes — opaque ptr]
    ---
    vtable (function pointers)
    ---
    + void  (*insert)(self, item, index)
    + void* (*get)(self, index)
    + void  (*remove)(self, index)
    + int   (*size)(self)
    + void  (*free)(self)
}

class array_list_impl <<internal>> {
    + void **data        [heap array of void*]
    + int   size
    + int   capacity     [doubles on overflow]
}

class linked_list_impl <<internal>> {
    + node *head
    + node *tail
    + int   size
    ....
    node: \{ void *data; node *next; node *prev; \}
}

class sorted_list_impl <<internal>> {
    + void **data        [sorted heap array]
    + int   size
    + int   capacity
    + comparator cmp
}

list::impl --> array_list_impl  : ARRAY_LIST
list::impl --> linked_list_impl : LINKED_LIST
list::impl --> sorted_list_impl : SORTED_LIST

' ═══════════════════════════════════════════════════════════════
' heap — vtable + opaque impl
' ═══════════════════════════════════════════════════════════════
class heap <<struct>> {
    + void  *impl          [8 bytes — opaque ptr]
    ---
    vtable (function pointers)
    ---
    + void  (*put)(self, item)
    + void* (*put_with_handle)(self, item)
    + void  (*decrease_key)(self, handle, val)  [NULL for binary_heap]
    + void  (*delete_node)(self, handle)        [NULL for binary_heap]
    + void* (*pop)(self)
    + void* (*peek)(self)
    + int   (*size)(self)
    + void  (*free)(self)
}

class binary_heap_impl <<internal>> {
    + void **data        [0-indexed array]
    + int   size
    + int   capacity     [doubles on overflow]
    + comparator cmp
}

class fib_heap_impl <<internal>> {
    + fib_node *min_node  [ptr to minimum root]
    + int       size
    + comparator cmp
    ....
    fib_node: \{ void *key; int degree; bool mark;\n          fib_node *parent, *child, *left, *right; \}
}

heap::impl --> binary_heap_impl : BINARY_HEAP
heap::impl --> fib_heap_impl    : FIBONACCI_HEAP

note bottom of binary_heap_impl
  Binary heap uses a flat array (0-indexed).
  Parent of node i  → (i−1)/2
  Children of node i → 2i+1, 2i+2
end note

note bottom of fib_heap_impl
  Fibonacci heap is a forest of
  min-heap-ordered trees linked
  in a circular doubly-linked list.
end note

' ═══════════════════════════════════════════════════════════════
' queue
' ═══════════════════════════════════════════════════════════════
class queue <<struct>> {
    + queue_entry *front   [NULL for empty]
    + queue_entry *rear
    + heap        *p_heap  [non-NULL for priority queue]
    + int          length
    ---
    vtable (function pointers)
    ---
    + void  (*initialize)(self, cmp)
    + int   (*enqueue)(self, data)
    + void* (*dequeue)(self)
    + int   (*is_empty)(self)
    + int   (*size)(self)
    + void  (*free)(self)
}

class queue_entry <<struct>> {
    + void        *data
    + queue_entry *next
}

queue::front --> queue_entry : linked list of entries
queue::p_heap --> heap       : priority queue path

' ═══════════════════════════════════════════════════════════════
' map
' ═══════════════════════════════════════════════════════════════
class map <<struct>> {
    + map_entry **buckets    [array of bucket heads]
    + int         capacity   [bucket count]
    + int         size       [element count]
    + hash_func   hash_func  [pluggable: bernstein/fnv1a/xor/…]
    + comparator  key_compare
    + pthread_mutex_t *lock  [non-NULL only for HASH_TABLE]
    ---
    vtable
    ---
    + void  (*put)(self, key, data)
    + void* (*get)(self, key)
    + void* (*remove)(self, key)
    + void  (*free)(self)
}

class map_entry <<struct>> {
    + void      *key
    + void      *data
    + map_entry *next   [chaining for collision]
}

map::buckets --> map_entry : bucket[i] → chain of entries

' ═══════════════════════════════════════════════════════════════
' lp_problem (solver)
' ═══════════════════════════════════════════════════════════════
class lp_problem <<struct>> {
    + matrix     *constraints  [m × (n+1) augmented matrix]
    + vector     *objective    [c coefficients]
    + vector     *bounds       [right-hand side b]
    + ProblemType type         [PROBLEM_MAX | PROBLEM_MIN]
    + double     *solution     [x1…xn after solve]
    + double      z_value      [optimal objective value]
    ---
    vtable
    ---
    + addConstraint(self, coeffs, bound)
    + setObjective(self, coeffs, type)
    + setBounds(self, bounds)
    + print(self)
}

class "vector (types.h)" <<struct>> {
    + double *data
    + int     size
    + int     capacity
}

class "matrix (matrix.h)" <<struct>> {
    + double **data      [rows × cols 2-D array]
    + int      rows
    + int      cols
}

lp_problem::constraints --> "matrix (matrix.h)"
lp_problem::objective   --> "vector (types.h)"
lp_problem::bounds      --> "vector (types.h)"

' ═══════════════════════════════════════════════════════════════
' tree — shared node struct + type-selected strategy
' ═══════════════════════════════════════════════════════════════
class tree <<struct>> {
    + tree_node *root
    + tree_node *nil   [sentinel for Red-Black]
    + comparator cmp
    + int         size
}

class tree_node <<struct>> {
    + void       *key
    + void       *value
    + tree_node  *left
    + tree_node  *right
    + tree_node  *parent
    + int         height  [AVL balance factor]
    + rb_color    color   [RB_RED | RB_BLACK]
}

tree::root --> tree_node : root of BST

note bottom of tree_node
  Both **height** and **color** fields
  are present in every node.
  AVL uses height; Red-Black uses color.
end note

' ═══════════════════════════════════════════════════════════════
' set — opaque impl + ops vtable
' ═══════════════════════════════════════════════════════════════
class set <<struct>> {
    + void  *impl          [hash_set_impl or tree_set_impl]
    ---
    + add / contains / remove / size / to_list / free
}

class hash_set_impl <<internal>> {
    + map *m   [delegates to hash map]
}

class tree_set_impl <<internal>> {
    + tree *t  [delegates to tree]
}

set::impl --> hash_set_impl  : SET_HASH
set::impl --> tree_set_impl  : SET_TREE
hash_set_impl --> map  : wraps
tree_set_impl --> tree : wraps

' ═══════════════════════════════════════════════════════════════
' stack — vtable + list-backed impl
' ═══════════════════════════════════════════════════════════════
class stack <<struct>> {
    + void *impl          [list * — array or linked]
    ---
    vtable (function pointers)
    ---
    + void  (*push)(self, item)
    + void* (*pop)(self)
    + void* (*top)(self)
    + int   (*is_empty)(self)
    + int   (*size)(self)
    + void  (*free)(self)
}

stack::impl --> list : delegates to list\n(ARRAY or LINKED)

' ═══════════════════════════════════════════════════════════════
' deque — circular buffer
' ═══════════════════════════════════════════════════════════════
class deque <<struct>> {
    + void **buffer       [circular array of void*]
    + int    capacity     [doubles on overflow]
    + int    size         [current element count]
    + int    front        [index of front element]
}

note bottom of deque
  Circular buffer: rear is computed as
  (front + size − 1) % capacity.
  Resizing linearises elements.
end note

' ═══════════════════════════════════════════════════════════════
' trie — prefix tree (256-ary)
' ═══════════════════════════════════════════════════════════════
class trie <<struct>> {
    + trie_node *root
    + size_t     word_count
}

class trie_node <<struct>> {
    + trie_node *children[256]  [one slot per ASCII byte]
    + bool       is_end
    + void      *value
    + size_t     subtree_words
    + unsigned   child_count
}

trie::root --> trie_node : root node
trie_node::children --> trie_node : recursive children

' ═══════════════════════════════════════════════════════════════
' bloom_filter — bit array + k hash functions
' ═══════════════════════════════════════════════════════════════
class bloom_filter <<struct>> {
    + uint8_t *bits          [bit array of m_bits bits]
    + size_t   m_bits        [array size in bits]
    + size_t   k_hashes      [number of hash functions]
    + size_t   expected_elements
    + double   target_fpp
    + size_t   items_added
}

note bottom of bloom_filter
  m = −n·ln(p) / ln(2)²
  k = (m/n)·ln(2)
  Uses seeded FNV-1a with
  double hashing for k indices.
end note

' ═══════════════════════════════════════════════════════════════
' graph — adjacency list or adjacency matrix
' ═══════════════════════════════════════════════════════════════
class graph <<struct>> {
    + graph_type           type     [DIRECTED | UNDIRECTED]
    + graph_representation rep      [ADJ_LIST | ADJ_MATRIX]
    + int          vertex_capacity
    + int          vertex_count
    + bool        *present          [active-vertex bitmap]
    + int        **vertex_ptrs      [sparse ID mapping]
    + list       **adj_lists        [per-vertex edge lists]
    + double      *adj_matrix       [row-major weight array]
}

class graph_weighted_edge <<struct>> {
    + int    from
    + int    to
    + double weight
}

graph::adj_lists --> graph_weighted_edge : ADJ_LIST path
note bottom of graph
  ADJ_LIST: adj_lists[v] = list of edges.
  ADJ_MATRIX: adj_matrix[v*cap+u] = weight
  (INFINITY means no edge).
end note

' ═══════════════════════════════════════════════════════════════
' sorter — vtable operating on lists
' ═══════════════════════════════════════════════════════════════
class sorter <<struct>> {
    + comparator cmp
    ---
    vtable (function pointers)
    ---
    + void  (*sort)(self, lst)
    + void  (*shuffle)(self, lst)
    + void  (*reverse)(self, lst)
    + int   (*binary_search)(self, lst, item)
    + void  (*swap)(self, lst, i, j)
    + void  (*min_max)(self, lst, &min, &max)
    + void* (*min)(self, lst)
    + void* (*max)(self, lst)
    + void  (*copy)(self, src, dest)
}

sorter --> list : operates on

@enduml
