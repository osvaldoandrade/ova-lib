@startuml factory-patterns
title ova-lib — Factory Pattern Relationships

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ArrowColor #444444
skinparam ClassBorderColor #666666
skinparam ClassBackgroundColor #FAFAFA

' ── List factory ────────────────────────────────────────────────────────────
package "List" {
    enum ListType {
        ARRAY_LIST
        LINKED_LIST
        SORTED_LIST
    }

    interface list <<vtable>> {
        + void *impl
        + insert(self, item, index)
        + get(self, index) : void*
        + remove(self, index)
        + size(self) : int
        + free(self)
    }

    class array_list_impl <<concrete>>
    class linked_list_impl <<concrete>>
    class sorted_list_impl <<concrete>>

    ListType ..> list : "create_list()"
    list *-- array_list_impl  : ARRAY_LIST
    list *-- linked_list_impl : LINKED_LIST
    list *-- sorted_list_impl : SORTED_LIST
}

' ── Heap factory ────────────────────────────────────────────────────────────
package "Heap" {
    enum HeapType {
        BINARY_HEAP
        FIBONACCI_HEAP
    }

    interface heap <<vtable>> {
        + void *impl
        + put(self, item)
        + put_with_handle(self, item) : void*
        + decrease_key(self, handle, value)
        + delete_node(self, handle)
        + pop(self) : void*
        + peek(self) : void*
        + size(self) : int
        + free(self)
    }

    class binary_heap_impl <<concrete>> {
        decrease_key = NULL
        delete_node  = NULL
    }
    class fibonacci_heap_impl <<concrete>>

    HeapType ..> heap : "create_heap()"
    heap *-- binary_heap_impl   : BINARY_HEAP
    heap *-- fibonacci_heap_impl : FIBONACCI_HEAP
}

' ── Queue factory ───────────────────────────────────────────────────────────
package "Queue" {
    enum queue_type {
        QUEUE_TYPE_NORMAL
        QUEUE_TYPE_PRIORITY
    }

    class queue <<concrete>> {
        + queue_entry *front
        + queue_entry *rear
        + heap *p_heap
        + int length
        + initialize(self, cmp)
        + enqueue(self, data) : int
        + dequeue(self) : void*
        + is_empty(self) : int
        + size(self) : int
        + free(self)
    }

    class linked_queue_impl <<concrete>>
    class heap_queue_impl <<concrete>>

    queue_type ..> queue : "create_queue()"
    queue *-- linked_queue_impl : QUEUE_TYPE_NORMAL
    queue *-- heap_queue_impl   : QUEUE_TYPE_PRIORITY
    heap_queue_impl --> heap    : uses
}

' ── Stack factory ───────────────────────────────────────────────────────────
package "Stack" {
    enum StackType {
        ARRAY_STACK
        LINKED_STACK
    }

    interface stack <<vtable>> {
        + void *impl
        + push(self, item)
        + pop(self) : void*
        + top(self) : void*
        + is_empty(self) : int
        + size(self) : int
        + free(self)
    }

    class array_stack_impl <<concrete>>
    class linked_stack_impl <<concrete>>

    StackType ..> stack : "create_stack()"
    stack *-- array_stack_impl  : ARRAY_STACK
    stack *-- linked_stack_impl : LINKED_STACK
}

' ── Map factory ─────────────────────────────────────────────────────────────
package "Map" {
    enum map_type {
        HASH_MAP
        HASH_TABLE
    }

    class map <<concrete>> {
        + map_entry **buckets
        + int capacity
        + int size
        + hash_func(key, cap) : int
        + comparator key_compare
        + pthread_mutex_t *lock
        + put(self, key, data)
        + get(self, key) : void*
        + remove(self, key) : void*
        + free(self)
    }

    map_type ..> map : "create_map()"
    note right of map : HASH_TABLE adds\npthread_mutex_t lock
}

' ── Set factory ─────────────────────────────────────────────────────────────
package "Set" {
    enum set_type {
        SET_HASH
        SET_TREE
    }

    interface set <<vtable>> {
        + add(s, element) : bool
        + contains(s, element) : bool
        + remove(s, element) : bool
        + size(s) : int
        + set_union / intersection / difference
        + set_to_list(s) : list*
    }

    class hash_set_impl <<concrete>>
    class tree_set_impl <<concrete>>

    set_type ..> set : "create_set()"
    set *-- hash_set_impl : SET_HASH
    set *-- tree_set_impl : SET_TREE
}

' ── Tree factory ────────────────────────────────────────────────────────────
package "Tree" {
    enum tree_type {
        TREE_AVL
        TREE_RED_BLACK
    }

    interface tree <<vtable>> {
        + insert(t, key, value)
        + search(t, key) : void*
        + delete(t, key)
        + min(t) : void*
        + max(t) : void*
        + predecessor(t, key) : void*
        + successor(t, key) : void*
        + range_query(t, low, high) : list*
        + in_order_traverse(t, cb)
        + size(t) : int
        + free(t)
    }

    class avl_tree_impl <<concrete>>
    class red_black_tree_impl <<concrete>>

    tree_type ..> tree : "create_tree()"
    tree *-- avl_tree_impl       : TREE_AVL
    tree *-- red_black_tree_impl : TREE_RED_BLACK
}

' ── Solver factory ──────────────────────────────────────────────────────────
package "Solver" {
    enum SolverType {
        SOLVER_SIMPLEX
        SOLVER_LAGRANGEAN_SIMPLEX
        SOLVER_BRANCH_AND_BOUND
        SOLVER_BRANCH_AND_CUT
    }

    class solver <<concrete>> {
        + SolverType type
        + solve(problem, out_tableau) : int
        + destroy(self)
    }

    class lp_problem <<concrete>> {
        + matrix *constraints
        + vector *objective
        + vector *bounds
        + ProblemType type
        + double *solution
        + double z_value
        + addConstraint(self, coeffs, bound)
        + setObjective(self, coeffs, type)
        + setBounds(self, bounds)
        + print(self)
    }

    SolverType ..> solver    : "create_solver()"
    solver      --> lp_problem : solves
    note bottom of solver : LAGRANGEAN/BRANCH variants\nreturn NULL (stub)
}

' ── Graph factory ──────────────────────────────────────────────────────────
package "Graph" {
    enum graph_type {
        GRAPH_DIRECTED
        GRAPH_UNDIRECTED
    }

    enum graph_representation {
        GRAPH_ADJACENCY_LIST
        GRAPH_ADJACENCY_MATRIX
    }

    class graph <<concrete>> {
        + graph_type type
        + graph_representation rep
        + int vertex_capacity
        + int vertex_count
        + graph_add_vertex(g, id)
        + graph_add_edge(g, from, to, w)
        + graph_bfs / graph_dfs : list*
        + graph_dijkstra / bellman_ford
        + graph_mst_prim / kruskal : list*
        + graph_free(g)
    }

    graph_type ..> graph            : "create_graph()"
    graph_representation ..> graph  : selects representation
}

' ── Trie factory ───────────────────────────────────────────────────────────
package "Trie" {
    class trie <<concrete>> {
        + trie_node *root
        + size_t word_count
        + trie_insert(t, word, value)
        + trie_search(t, word) : void*
        + trie_delete(t, word) : bool
        + trie_starts_with(t, prefix) : bool
        + trie_get_words_with_prefix(t, prefix) : list*
        + trie_count_words(t) : int
        + trie_free(t)
    }

    note bottom of trie : "create_trie()" — no parameters
}

' ── Bloom Filter factory ───────────────────────────────────────────────────
package "Bloom Filter" {
    class bloom_filter <<concrete>> {
        + uint8_t *bits
        + size_t m_bits, k_hashes
        + size_t items_added
        + bloom_filter_add(bf, elem, len)
        + bloom_filter_might_contain(bf, elem, len) : bool
        + bloom_filter_current_fpp(bf) : double
        + bloom_filter_clear(bf)
        + bloom_filter_free(bf)
    }

    note bottom of bloom_filter : "create_bloom_filter(n, p)"\nn = expected elements,\np = target false-positive rate
}

' ── Sorter factory ─────────────────────────────────────────────────────────
package "Sorter" {
    interface sorter <<vtable>> {
        + comparator cmp
        + sort(self, lst)
        + shuffle(self, lst)
        + reverse(self, lst)
        + binary_search(self, lst, item) : int
        + swap(self, lst, i, j)
        + min_max(self, lst, &min, &max)
        + min(self, lst) : void*
        + max(self, lst) : void*
        + copy(self, src, dest)
    }

    note bottom of sorter : "create_sorter(list, cmp)"\nQuicksort-based implementation
    sorter --> list : operates on
}

' ── Deque factory ──────────────────────────────────────────────────────────
package "Deque" {
    class deque <<concrete>> {
        + void **buffer
        + int capacity, size, front
        + deque_push_front / push_back
        + deque_pop_front / pop_back
        + deque_peek_front / peek_back
        + deque_get(d, index) : void*
        + deque_size / is_empty
        + deque_free(d)
    }

    note bottom of deque : "create_deque(capacity)"\nCircular buffer
}

' ── Matrix / Vector factory ────────────────────────────────────────────────
package "Matrix / Vector" {
    interface matrix <<vtable>> {
        + double **data
        + int rows, cols
        + add(self, other) : matrix*
        + subtract(self, other) : matrix*
        + multiply(self, other) : matrix*
        + determinant(self, &err) : double
        + transpose(self) : matrix*
        + inverse(self) : matrix*
        + resize(self, rows, cols) : int
        + copy(self) : matrix*
        + print(self)
        + destroy(self)
    }

    class vector <<concrete>> {
        + double *data
        + int size
        + resize(self, newSize)
        + print(self)
        + destroy(self)
    }

    note bottom of matrix  : "create_matrix(rows, cols)"
    note bottom of vector  : "create_vector(size)"
}

@enduml
